{
  "name": "apollo-agent-cli",
  "version": "0.1.0",
  "description": "CLI and MCP server for Apollo.io — wraps the full Apollo API for agent-native use",
  "type": "module",
  "bin": {
    "apollo": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:e2e": "npm run build && node scripts/e2e-apollo-live.mjs",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "apollo",
    "apollo-io",
    "sales-intelligence",
    "prospecting",
    "enrichment",
    "crm",
    "sequences",
    "outbound",
    "lead-generation",
    "cli",
    "mcp",
    "ai-agent"
  ],
  "author": "bcharleson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bcharleson/apollo-agent-cli.git"
  },
  "bugs": {
    "url": "https://github.com/bcharleson/apollo-agent-cli/issues"
  },
  "homepage": "https://github.com/bcharleson/apollo-agent-cli#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
